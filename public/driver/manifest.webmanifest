{
  "name": "RideOn Driver",
  "short_name": "Driver",
  "description": "Manage your trips, accept booking offers, and track your earnings.",
  "id": "/driver/",
  "start_url": "/driver",
  "scope": "/driver/",
  "display": "standalone",
