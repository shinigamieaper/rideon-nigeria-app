      "purpose": "maskable"
    }
  ],
  "shortcuts": [
    {
      "name": "New Booking Requests",
      "short_name": "Requests",
      "description": "View and accept new trip offers",
      "url": "/driver/bookings/new",
      "icons": [{ "src": "/RIDEONNIGERIA%20LOGO.png", "sizes": "1024x1024" }]
    },
    {
      "name": "My Schedule",
      "short_name": "Schedule",
      "description": "View your upcoming trips",
      "url": "/driver/schedule",
      "icons": [{ "src": "/RIDEONNIGERIA%20LOGO.png", "sizes": "1024x1024" }]
    },
    {
      "name": "Earnings",
      "short_name": "Earnings",
      "description": "Track your earnings and payouts",
      "url": "/driver/earnings",
      "icons": [{ "src": "/RIDEONNIGERIA%20LOGO.png", "sizes": "1024x1024" }]
    }
  ],
  "categories": ["business", "productivity", "travel"]
}
